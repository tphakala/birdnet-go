#!/bin/sh
set -eu  # Exit on error, treat unset variables as error

# Go backend checks
echo "ЁЯФН Running backend pre-commit checks..."

# Check if any Go files are being committed (including renames, excluding generated/vendor)
GO_FILES=$(git diff --cached --name-only --diff-filter=ACMR | \
  grep '\.go$' | \
  grep -v '^vendor/' | \
  grep -v '^third_party/' | \
  grep -v '_gen\.go$' | \
  grep -v '/generated/' | \
  grep -v '\.pb\.go$' || true)

if [ -n "$GO_FILES" ]; then
  echo "ЁЯУЭ Go files detected in commit, running golangci-lint..."
  
  # Check if golangci-lint is available
  if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "тЭМ golangci-lint is not installed or not in PATH"
    echo "ЁЯТб Install it with: curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b \$(go env GOPATH)/bin v1.61.0"
    exit 1
  fi
  
  # Check and auto-format Go files
  echo "   Checking Go code formatting..."
  UNFORMATTED=$(echo "$GO_FILES" | xargs gofmt -l)
  
  if [ -n "$UNFORMATTED" ]; then
    echo "ЁЯФз Auto-formatting Go files:"
    echo "$UNFORMATTED" | sed 's/^/     /'
    
    # Format the files
    echo "$UNFORMATTED" | xargs gofmt -w
    
    # Re-stage the formatted files
    echo "$UNFORMATTED" | xargs git add
    
    echo "тЬЕ Go files formatted and re-staged automatically"
  else
    echo "тЬЕ All Go files are properly formatted"
  fi
  
  # Run golangci-lint
  echo "   Linting Go files..."
  if ! golangci-lint run -v; then
    echo "тЭМ golangci-lint found issues in Go files"
    echo "ЁЯТб Fix the issues above before committing"
    echo "тЪая╕П  Note: --no-verify bypasses are not accepted in this project"
    exit 1
  fi
  echo "тЬЕ golangci-lint passed for all Go files"
else
  echo "ЁЯУД No Go files in this commit, skipping golangci-lint"
fi

# Check species dictionaries when OpenFauna data or generator changes
SPECIES_DICT_TRIGGER=$(git diff --cached --name-only --diff-filter=ACMR | \
  grep -E 'internal/openfauna/data/translations\.csv\.gz$|internal/openfauna/data/SOURCE\.txt$|internal/openfauna/data/locales\.txt$|internal/openfauna/dictionary\.go$|internal/openfauna/resolver\.go$|internal/speciesdict/gen/main\.go$|internal/speciesdict/data/' || true)

if [ -n "$SPECIES_DICT_TRIGGER" ]; then
  echo "ЁЯРж Checking species dictionaries..."
  go generate ./internal/speciesdict
  if ! git diff --quiet -- internal/speciesdict/data; then
    echo "тЭМ Species dictionaries are out of date."
    echo "ЁЯТб Run: go generate ./internal/speciesdict, then stage internal/speciesdict/data"
    exit 1
  fi
  echo "тЬЕ Species dictionaries are in sync"
fi

# Frontend checks
echo "ЁЯФН Running frontend pre-commit checks..."
cd frontend || exit 1

# Check i18n key sync if translation files are staged
I18N_FILES=$(git diff --cached --name-only --diff-filter=ACMR | \
  grep 'frontend/static/messages/.*\.json$' || true)

if [ -n "$I18N_FILES" ]; then
  echo "ЁЯМН Checking i18n key sync..."
  npm run i18n:sync:check || {
    echo "тЭМ i18n keys out of sync. Run: cd frontend && npm run i18n:sync"
    exit 1
  }
  echo "тЬЕ i18n keys in sync"
fi

# Check generated i18n types when en.json, the generator, or the generated file changes.
# The frontend/ prefix is optional so the match still works under git diff.relative=true
# (paths come out relative to the frontend/ cwd set above).
I18N_TYPES_TRIGGER=$(git diff --cached --name-only --diff-filter=ACMR | \
  grep -E '(frontend/)?static/messages/en\.json$|(frontend/)?src/lib/i18n/generateTypes\.ts$|(frontend/)?src/lib/i18n/types\.generated\.ts$' || true)

if [ -n "$I18N_TYPES_TRIGGER" ]; then
  echo "ЁЯМН Checking generated i18n types..."
  npm run generate:i18n-types:check || {
    echo "тЭМ i18n types out of sync. Run: cd frontend && npm run generate:i18n-types"
    exit 1
  }
  echo "тЬЕ i18n types in sync"
fi

# Run lint-staged for staged files first (faster feedback)
echo "ЁЯз╣ Running lint-staged..."
npx lint-staged || exit 1

# Run TypeScript/Svelte type checking on staged files only
echo "ЁЯУЭ Type checking staged files..."
# Get staged .ts, .svelte files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|svelte)$' | head -20)

if [ -n "$STAGED_FILES" ]; then
  echo "Checking types for staged files..."
  npm run typecheck || {
    echo "тЭМ TypeScript errors found in staged files."
    echo "ЁЯТб Fix errors before committing"
    echo "тЪая╕П  Note: --no-verify bypasses are not accepted in this project"
    exit 1
  }
else
  echo "тД╣я╕П No TypeScript/Svelte files staged, skipping typecheck"
fi

echo "тЬЕ All pre-commit checks passed!"
