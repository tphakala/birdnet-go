{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:go": "npm run build && cd .. && go generate ./frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint",
    "check:fix": "npm run format && npm run lint:fix",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "check:all": "npm run format:check && npm run lint && npm run lint:css && npm run typecheck && npm run ast:all",
    "lint:css": "stylelint 'src/**/*.{css,svelte}'",
    "lint:css:fix": "stylelint 'src/**/*.{css,svelte}' --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --reporter=verbose --coverage.enabled=false",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:integration:auto": "INTEGRATION_AUTO_BACKEND=true vitest --config vitest.integration.config.ts",
    "test:reverse-proxy": "vitest run --config vitest.reverse-proxy.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:watch": "vitest --config vitest.browser.config.ts",
    "depcheck": "npx depcheck --skip-missing",
    "commitlint": "npx commitlint --from HEAD~1 --to HEAD --verbose",
    "analyze:deps": "madge --extensions ts,js,svelte --summary src/",
    "analyze:circular": "madge --extensions ts,js,svelte --circular src/",
    "analyze:deps:json": "madge --extensions ts,js,svelte --json src/",
    "analyze:orphans": "madge --extensions ts,js,svelte --orphans src/",
    "analyze:duplicates": "jscpd src/",
    "analyze:duplicates:html": "jscpd --reporters html,console src/",
    "analyze:all": "npm run analyze:circular && npm run analyze:duplicates",
    "ast:check": "sg scan src/",
    "ast:security": "sg scan src/ --config rules/ast-grep-security.yml",
    "ast:svelte5": "sg scan src/ --config rules/ast-grep-svelte5.yml",
    "ast:migration": "sg scan src/ --config rules/ast-grep-svelte4-migration.yml",
    "ast:best-practices": "sg scan src/ --config rules/ast-grep-svelte5-best-practices.yml",
    "ast:test": "sg scan src/ --rule rules/simple-test.yml",
    "ast:fix": "sg scan -U src/",
    "ast:all": "npm run ast:security && npm run ast:svelte5 && npm run ast:migration && npm run ast:best-practices",
    "lint:bare-colors": "bash scripts/check-bare-color-classes.sh",
    "test:a11y": "vitest run --reporter=verbose -t \"Accessibility\"",
    "test:a11y:watch": "vitest -t \"Accessibility\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "generate:i18n-types": "npx tsx src/lib/i18n/generateTypes.ts",
    "generate:i18n-types:check": "npx tsx src/lib/i18n/generateTypes.ts --check",
    "i18n:validate": "npx tsx src/lib/i18n/validateTranslations.ts",
    "i18n:validate:strict": "npx tsx src/lib/i18n/validateTranslations.ts --strict",
    "i18n:validate:ci": "npx tsx src/lib/i18n/validateTranslations.ts --min-coverage 85 --fail-on-warnings",
    "i18n:validate:json": "npx tsx src/lib/i18n/validateTranslations.ts --json",
    "i18n:report": "npx tsx src/lib/i18n/validateTranslations.ts --report",
    "i18n:report:md": "npx tsx src/lib/i18n/validateTranslations.ts --report --format=markdown",
    "i18n:scan": "npx tsx src/lib/i18n/validateUsage.ts",
    "i18n:check-usage": "npx tsx src/lib/i18n/validateUsage.ts",
    "i18n:find-unused": "npx tsx src/lib/i18n/validateUsage.ts --show-unused",
    "i18n:sync": "npx tsx src/lib/i18n/syncTranslations.ts",
    "i18n:sync:check": "npx tsx src/lib/i18n/syncTranslations.ts --check",
    "i18n:validate:full": "npm run i18n:sync:check && npm run generate:i18n-types:check && npm run i18n:validate && npm run i18n:check-usage",
    "prepare": "husky",
    "analyze:bundle": "npm run build && npx vite-bundle-analyzer dist",
    "analyze:bundle:size": "npm run build",
    "audit:security": "npm audit --audit-level=high",
    "audit:outdated": "npm outdated",
    "check:deps": "npx depcheck && npm run audit:security"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.css": [
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@formatjs/icu-messageformat-parser": "^3.5.11",
    "@playwright/test": "^1.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.4",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vitest/ui": "^4.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-svelte": "^3.19.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "playwright": "^1.56.1",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.2",
    "typescript": "^6.0.3",
    "vite": "8.1.0",
    "vite-bundle-analyzer": "^1.3.8",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@bybas/weather-icons": "^2.0.0",
    "@lucide/svelte": "^1.21.0",
    "@sentry/browser": "^10.59.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "d3": "^7.9.0",
    "d3-time-format": "^4.1.0",
    "hls.js": "^1.6.16",
    "maplibre-gl": "^5.24.0",
    "svelte-dnd-action": "^0.9.70"
  },
  "bundleDependencies": [
    "svelte"
  ],
  "overrides": {
    "flatted": "3.4.2",
    "lru-cache": "11.2.7",
    "undici": "7.28.0",
    "esrap": "2.2.11"
  }
}
